<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#F9F9F9"
        android:elevation="4dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Settings"
            android:textColor="#0A192F"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <LinearLayout
                android:id="@+id/layoutNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="연구 참여자 이름(닉네임) 입력"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="이름 또는 닉네임"
                    android:textStyle="bold"
                    android:textColorHint="#800A192F"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSaveName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginHorizontal="24dp"
                    android:text="이름 저장"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_blue"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutNameDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="참여자 이름"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#0A192F"/>
                <TextView
                    android:id="@+id/tvNameDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginVertical="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오버레이 권한을 허용해주세요."
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />
            <Button
                android:id="@+id/btnOverlay"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="오버레이 권한 설정"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginVertical="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="숏폼 사용 감지를 위해\n접근성 서비스 활성화가 필요합니다."
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/tvAccessibilityStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상태: 확인 중..."
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="접근성 서비스 설정"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginVertical="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PIP(화면 속 화면) 권한 설정이 필요합니다."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp" />
            <Button
                android:id="@+id/btnPipYoutube"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="유튜브 PIP 설정"
                android:layout_marginBottom="8dp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />
            <Button
                android:id="@+id/btnPipInstagram"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="인스타그램 PIP 설정"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginVertical="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개입 타입 설정"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />
            <EditText
                android:id="@+id/etTypeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0, 1, 2 입력"
                android:textStyle="bold"
                android:textColor="#0A192F"
                android:textColorHint="#800A192F"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginBottom="12dp" />
            <Button
                android:id="@+id/btnSaveType"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="액티비티 타입 저장"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginVertical="24dp" />

            <TextView
                android:id="@+id/tvInterventionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상태 확인 중..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <EditText
                android:id="@+id/etInterventionCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="인증 코드 입력"
                android:textStyle="bold"
                android:textColorHint="#800A192F"
                android:gravity="center"
                android:layout_marginBottom="12dp" />
            <Button
                android:id="@+id/btnToggleIntervention"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="24dp"
                android:text="개입 상태 변경 (시작/종료)"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                app:backgroundTint="@null" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>