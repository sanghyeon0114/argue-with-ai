<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/chat_bubble_left_gap"
    android:paddingEnd="0dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/bubbleOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_bubble_out"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constrainedWidth="true"
        app:layout_constraintWidth_max="@dimen/chat_bubble_max_width">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivTyping"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="0dp"
            android:src="@drawable/ic_typing"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:id="@+id/vTail"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_bubble_tail_out"
        android:translationX="-1dp"
        app:layout_constraintTop_toTopOf="@id/bubbleOut"
        app:layout_constraintEnd_toEndOf="@id/bubbleOut"
        android:layout_marginEnd="-8dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:text="@string/time_format"
        android:textSize="11sp"
        android:textColor="#99000000"
        app:layout_constraintBottom_toBottomOf="@id/bubbleOut"
        app:layout_constraintEnd_toStartOf="@id/bubbleOut" />

</androidx.constraintlayout.widget.ConstraintLayout>