<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="0dp"
    android:paddingEnd="@dimen/chat_bubble_right_gap"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/ivProfile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@drawable/ic_launcher_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="엄동선"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/ivProfile"
        app:layout_constraintTop_toTopOf="@id/ivProfile"
        app:layout_constraintBottom_toBottomOf="@id/ivProfile" />

    <View
        android:id="@+id/vTail"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_bubble_tail_in"
        android:translationX="1dp"
        app:layout_constraintTop_toTopOf="@id/bubbleIn"
        app:layout_constraintStart_toStartOf="@id/bubbleIn"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/bubbleIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/bg_bubble_in"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivProfile"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constrainedWidth="true"
        app:layout_constraintWidth_max="260dp">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="300dp"
            android:textColor="@android:color/black"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivTyping"
            android:layout_width="26dp"
            android:layout_height="20dp"
            android:padding="0dp"
            android:src="@drawable/ic_typing"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text="..."
        android:textColor="#99000000"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@id/bubbleIn"
        app:layout_constraintStart_toEndOf="@id/bubbleIn" />

</androidx.constraintlayout.widget.ConstraintLayout>